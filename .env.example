# Copy to .env and fill in. NEVER commit .env.

# --- Groq (required) ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Model used by Answer / Structurer / Orchestrator agents
DOCJUDGE_LLM_MODEL=llama-3.3-70b-versatile

# Different model for the Judge agent — reduces shared blind spots
# (plan risk note: judge should not share the answer model's failure modes).
# qwen3-32b verified working with Groq structured outputs as of 2026-06.
DOCJUDGE_JUDGE_MODEL=qwen/qwen3-32b

# --- Embeddings ---
DOCJUDGE_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- ChromaDB ---
DOCJUDGE_CHROMA_DIR=./data/chroma
DOCJUDGE_CHROMA_COLLECTION=docjudge

# --- Retrieval ---
DOCJUDGE_TOP_K=10
DOCJUDGE_MAX_RETRIES=2

# --- Upload limits (guardrails) ---

# --- Rate limiting (Groq free tier) ---
# 429 backoff attempts; the Groq client honors the Retry-After header.
DOCJUDGE_LLM_MAX_RETRIES=5

# --- Logging ---
DOCJUDGE_LOG_DIR=./logs
DOCJUDGE_LOG_FILE=docjudge.log
DOCJUDGE_LOG_LEVEL=INFO

# --- LangSmith tracing (recommended; shows every node + LLM call in the UI) ---
# Get a free key at https://smith.langchain.com -> Settings -> API Keys.
# Set TRACING to true and paste the key; falls back to file/console logs if off.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=docjudge
